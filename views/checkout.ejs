<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>

<div class="page-header">
  <div class="container">
    <h1>💳 Checkout</h1>
    <p style="margin:4px 0 0; color:var(--gray); font-weight:500;">Complete your order</p>
  </div>
</div>

<section style="background:var(--light); padding:40px 0;">
  <div class="container">
    <form action="/orders/place" method="POST">
      <div class="row g-4">
        <div class="col-lg-8">
          <!-- Delivery Address -->
          <div style="background:white; border-radius:var(--radius); padding:28px; box-shadow:var(--shadow); border:1.5px solid var(--border); margin-bottom:20px;">
            <h5 style="font-weight:800; margin-bottom:20px;"><i class="bi bi-geo-alt-fill me-2" style="color:var(--primary)"></i>Delivery Address</h5>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label-green">Street Address *</label>
                <input type="text" name="street" class="form-control-green" value="<%= user.address && user.address.street ? user.address.street : '' %>" placeholder="House no, street, area..." required>
              </div>
              <div class="col-md-5">
                <label class="form-label-green">City *</label>
                <input type="text" name="city" class="form-control-green" value="<%= user.address && user.address.city ? user.address.city : '' %>" placeholder="City" required>
              </div>
              <div class="col-md-4">
                <label class="form-label-green">State *</label>
                <input type="text" name="state" class="form-control-green" value="<%= user.address && user.address.state ? user.address.state : '' %>" placeholder="State" required>
              </div>
              <div class="col-md-3">
                <label class="form-label-green">Pincode *</label>
                <input type="text" name="pincode" class="form-control-green" value="<%= user.address && user.address.pincode ? user.address.pincode : '' %>" placeholder="110001" required pattern="\d{6}">
              </div>
            </div>
          </div>

          <!-- Payment Method -->
          <div style="background:white; border-radius:var(--radius); padding:28px; box-shadow:var(--shadow); border:1.5px solid var(--border);">
            <h5 style="font-weight:800; margin-bottom:20px;"><i class="bi bi-wallet2 me-2" style="color:var(--primary)"></i>Payment Method</h5>
            <div style="display:flex; gap:14px; flex-wrap:wrap;">
              <label style="flex:1; min-width:160px; cursor:pointer;">
                <input type="radio" name="paymentMethod" value="COD" checked style="display:none;" class="payment-radio">
                <div class="payment-option" style="border:2px solid var(--primary); background:var(--primary-pale); border-radius:var(--radius-sm); padding:16px 20px; text-align:center; transition:var(--transition);">
                  <div style="font-size:1.8rem;">💵</div>
                  <div style="font-weight:800; margin-top:6px;">Cash on Delivery</div>
                  <div style="font-size:0.8rem; color:var(--gray);">Pay when delivered</div>
                </div>
              </label>
              <label style="flex:1; min-width:160px; cursor:pointer;">
                <input type="radio" name="paymentMethod" value="Online" style="display:none;" class="payment-radio">
                <div class="payment-option" style="border:2px solid var(--border); border-radius:var(--radius-sm); padding:16px 20px; text-align:center; transition:var(--transition);">
                  <div style="font-size:1.8rem;">💳</div>
                  <div style="font-weight:800; margin-top:6px;">Online Payment</div>
                  <div style="font-size:0.8rem; color:var(--gray);">UPI / Cards</div>
                </div>
              </label>
            </div>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
          <div class="order-summary-card">
            <h5 style="font-weight:800; margin-bottom:16px;">Order Summary</h5>
            <div style="max-height:240px; overflow-y:auto; margin-bottom:16px;">
              <% cart.forEach(item => { %>
              <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--gray-light);">
                <img src="<%= item.image %>" style="width:48px; height:48px; border-radius:8px; object-fit:cover; background:var(--primary-pale);">
                <div style="flex:1;">
                  <div style="font-size:0.88rem; font-weight:700;"><%= item.name %></div>
                  <div style="font-size:0.8rem; color:var(--gray);">×<%= item.quantity %></div>
                </div>
                <div style="font-weight:700; font-size:0.9rem;">₹<%= (item.price * item.quantity).toFixed(0) %></div>
              </div>
              <% }) %>
            </div>
            <div class="order-summary-row">
              <span>Subtotal</span><span>₹<%= (subtotal || 0).toFixed(0) %></span>
            </div>
            <div class="order-summary-row">
              <span>Delivery</span>
              <span style="color:<%= deliveryCharge===0 ? 'var(--primary-dark)' : 'inherit' %>">
                <%= deliveryCharge === 0 ? 'FREE 🎉' : '₹' + deliveryCharge %>
              </span>
            </div>
            <div class="order-summary-row total">
              <span>Total</span><span>₹<%= (total || 0).toFixed(0) %></span>
            </div>
            <button type="submit" class="btn-primary-green w-100 mt-3" style="padding:14px; font-size:1rem; justify-content:center;">
              <i class="bi bi-bag-check"></i> Place Order
            </button>
            <a href="/cart" class="btn-outline-green w-100 mt-2" style="padding:11px; justify-content:center;">
              <i class="bi bi-arrow-left"></i> Back to Cart
            </a>
          </div>
        </div>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
document.querySelectorAll('.payment-radio').forEach(radio => {
  radio.addEventListener('change', function() {
    document.querySelectorAll('.payment-option').forEach(opt => {
      opt.style.borderColor = 'var(--border)';
      opt.style.background = 'transparent';
    });
    this.nextElementSibling.style.borderColor = 'var(--primary)';
    this.nextElementSibling.style.background = 'var(--primary-pale)';
  });
});
</script>
</body>
</html>

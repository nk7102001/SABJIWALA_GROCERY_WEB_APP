<%- include('layout-top') %>

<div style="max-width:700px;">
  <div style="display:flex; align-items:center; gap:14px; margin-bottom:28px;">
    <a href="/admin/products" style="background:white; border:1.5px solid var(--border); border-radius:10px; padding:8px 14px; text-decoration:none; color:var(--secondary); font-weight:700;"><i class="bi bi-arrow-left"></i></a>
    <h2 style="font-family:var(--font-display); font-size:1.8rem; font-weight:800; margin:0;"><%= product ? 'Edit' : 'Add' %> Product</h2>
  </div>

  <div style="background:white; border-radius:var(--radius); padding:32px; box-shadow:var(--shadow); border:1.5px solid var(--border);">
    <form action="<%= product ? '/admin/products/edit/' + product._id : '/admin/products/add' %>" method="POST">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label-green">Product Name *</label>
          <input type="text" name="name" class="form-control-green" value="<%= product ? product.name : '' %>" required placeholder="e.g. Fresh Tomatoes">
        </div>
        <div class="col-12">
          <label class="form-label-green">Description</label>
          <textarea name="description" class="form-control-green" rows="3" placeholder="Product description..."><%= product ? product.description : '' %></textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label-green">Price (₹) *</label>
          <input type="number" name="price" class="form-control-green" value="<%= product ? product.price : '' %>" required min="0" step="0.01">
        </div>
        <div class="col-md-6">
          <label class="form-label-green">Original Price (₹)</label>
          <input type="number" name="originalPrice" class="form-control-green" value="<%= product ? product.originalPrice : '' %>" min="0" step="0.01" placeholder="MRP before discount">
        </div>
        <div class="col-md-6">
          <label class="form-label-green">Category *</label>
          <select name="category" class="form-control-green" required>
            <% ['Vegetables','Fruits','Dairy','Grains','Snacks','Beverages','Other'].forEach(cat => { %>
              <option value="<%= cat %>" <%= product && product.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label-green">Unit</label>
          <input type="text" name="unit" class="form-control-green" value="<%= product ? product.unit : 'kg' %>" placeholder="kg / piece / litre">
        </div>
        <div class="col-md-3">
          <label class="form-label-green">Stock *</label>
          <input type="number" name="stock" class="form-control-green" value="<%= product ? product.stock : 100 %>" required min="0">
        </div>
        <div class="col-md-9">
          <label class="form-label-green">Image URL</label>
          <input type="url" name="image" class="form-control-green" value="<%= product ? product.image : '' %>" placeholder="https://... (Unsplash or direct URL)">
        </div>
        <div class="col-md-3">
          <label class="form-label-green">Discount %</label>
          <input type="number" name="discount" class="form-control-green" value="<%= product ? product.discount : 0 %>" min="0" max="100">
        </div>
        <div class="col-12">
          <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
            <input type="checkbox" name="isFeatured" value="on" <%= product && product.isFeatured ? 'checked' : '' %> style="width:18px; height:18px; accent-color:var(--primary);">
            <span class="form-label-green" style="margin:0;">⭐ Featured Product (show on homepage)</span>
          </label>
        </div>
        <div class="col-12" style="display:flex; gap:12px; margin-top:8px;">
          <button type="submit" class="btn-primary-green" style="padding:12px 28px;">
            <i class="bi bi-check2-circle"></i> <%= product ? 'Update' : 'Add' %> Product
          </button>
          <a href="/admin/products" class="btn-outline-green" style="padding:12px 24px;">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

<%- include('layout-top') %>

<h2 style="font-family:var(--font-display); font-size:1.8rem; font-weight:800; margin-bottom:24px;">All Orders</h2>

<div class="admin-table">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Items</th>
        <th>Total</th>
        <th>Date</th>
        <th>Status</th>
        <th>Update</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders.length === 0) { %>
      <tr><td colspan="7" style="text-align:center; padding:30px; color:var(--gray);">No orders yet.</td></tr>
      <% } %>
      <% orders.forEach(order => { %>
      <tr>
        <td style="font-weight:700;">#<%= order._id.toString().slice(-8).toUpperCase() %></td>
        <td>
          <div style="font-weight:700;"><%= order.user ? order.user.name : 'N/A' %></div>
          <div style="font-size:0.8rem; color:var(--gray);"><%= order.user ? order.user.email : '' %></div>
        </td>
        <td>
          <% order.items.slice(0,2).forEach(item => { %>
            <div style="font-size:0.82rem;"><%= item.name %> ×<%= item.quantity %></div>
          <% }) %>
          <% if (order.items.length > 2) { %><div style="font-size:0.78rem; color:var(--gray);">+<%= order.items.length - 2 %> more</div><% } %>
        </td>
       <td style="font-weight:800; color:var(--primary-dark);">₹<%= (order.totalPrice || 0).toFixed(0) %></td>

        <td style="font-size:0.85rem;"><%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></td>
        <td><span class="order-status status-<%= order.status.replace(/ /g,'.') %>"><%= order.status %></span></td>
        <td>
          <form action="/admin/orders/update-status/<%= order._id %>" method="POST" style="display:flex; gap:6px; align-items:center;">
            <select name="status" class="form-select form-select-sm" style="font-size:0.8rem; border:1.5px solid var(--border); border-radius:var(--radius-sm); min-width:130px;">
              <% ['Pending','Confirmed','Processing','Out for Delivery','Delivered','Cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
            <button type="submit" class="btn-primary-green" style="padding:5px 10px; font-size:0.78rem; white-space:nowrap;">Update</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

<%- include('layout-top') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
  <div>
    <h2 style="font-family:var(--font-display); font-size:1.8rem; font-weight:800; margin:0;">Dashboard</h2>
    <p style="color:var(--gray); margin:4px 0 0; font-size:0.9rem;">Welcome to SABJIWALA Admin Panel</p>
  </div>
  <a href="/admin/products/add" class="btn-primary-green"><i class="bi bi-plus-circle"></i> Add Product</a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card">
      <div class="admin-stat-icon">📦</div>
      <div class="admin-stat-number"><%= productCount %></div>
      <div style="color:var(--gray); font-weight:600; font-size:0.88rem;">Total Products</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card" style="border-left-color:#3498db;">
      <div class="admin-stat-icon">🛒</div>
      <div class="admin-stat-number"><%= orderCount %></div>
      <div style="color:var(--gray); font-weight:600; font-size:0.88rem;">Total Orders</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card" style="border-left-color:#9b59b6;">
      <div class="admin-stat-icon">👥</div>
      <div class="admin-stat-number"><%= userCount %></div>
      <div style="color:var(--gray); font-weight:600; font-size:0.88rem;">Registered Users</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card" style="border-left-color:#f39c12;">
      <div class="admin-stat-icon">💰</div>
      <div class="admin-stat-number">₹<%= (revenue || 0).toFixed(0) %></div>
      <div style="color:var(--gray); font-weight:600; font-size:0.88rem;">Total Revenue</div>
    </div>
  </div>
</div>

<!-- Recent Orders -->
<div class="admin-table">
  <div style="padding:20px 20px 0; display:flex; justify-content:space-between; align-items:center;">
    <h5 style="font-weight:800; margin:0;">Recent Orders</h5>
    <a href="/admin/orders" style="font-size:0.88rem; font-weight:700; color:var(--primary-dark); text-decoration:none;">View All →</a>
  </div>
  <div style="padding:10px;">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% if (recentOrders.length === 0) { %>
      <tr><td colspan="5" style="text-align:center; padding:24px; color:var(--gray);">No orders yet.</td></tr>
      <% } %>
      <% recentOrders.forEach(order => { %>
      <tr>
        <td style="font-weight:700;">#<%= order._id.toString().slice(-8).toUpperCase() %></td>
        <td><%= order.user ? order.user.name : 'N/A' %></td>
        <td style="font-weight:700; color:var(--primary-dark);">₹<%= (order.totalPrice || 0).toFixed(0) %></td>
        <td><span class="order-status status-<%= order.status.replace(/ /g,'.') %>"><%= order.status %></span></td>
        <td style="font-size:0.85rem;"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</div>

</div><!-- end admin-content -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
